# ─── WordPress Architecture ──────────────────────────────────────────────────
/wp-admin/
/wp-includes/
/wp-*.php
/xmlrpc.php
/license.txt
/readme.html
!/wp-config-sample.php
!/index.php
!/.htaccess

# Content Folders
/wp-content/uploads/*
!/wp-content/uploads/2026/03/ # Permitir assets de la Fase 3
/wp-content/backup-db/
/wp-content/cache/
/wp-content/upgrade/

# ─── Credenciales y Archivos Sensibles ────────────────────────────────────────
# Variables de entorno — NUNCA en git
.env
.env.*
!.env.example

# Certificados y claves criptográficas
# Nota: archivos ya trackeados de Wordfence (*.pem/*.key en wp-content/plugins/wordfence/)
# no se ven afectados porque gitignore solo actúa sobre archivos NO trackeados.
# Se añaden excepciones explícitas para los archivos del plugin Wordfence (claves públicas,
# no credenciales) en caso de que alguien haga "git rm --cached" y los quiera reincorporar.
*.pem
*.key
*.p12
*.pfx
*.ovpn
*.ppk
!wp-content/plugins/wordfence/**/*.pem
!wp-content/plugins/wordfence/**/*.key

# Claves SSH
id_rsa
id_rsa.pub
id_rsa.*
id_ed25519
id_ed25519.pub
id_ed25519.*
id_ecdsa
id_ecdsa.pub
id_dsa
id_dsa.pub

# Configuración local de herramientas (p.ej. Azure Functions, VSCode, etc.)
local.settings.json
appsettings.local.json

gano_sftp_manager.py
# Scripts de operaciones destructivas / one-off (mantener solo en local)
run_cleanup.py
run_db_recovery.py
run_local_*.py
import_staging_db.py
cleanup_staging_db.py
wp-config-staging.php
mwp_db/
deploy.ps1

# ─── Documentos y Binarios ────────────────────────────────────────────────────
*.pdf
# Excepción: auditorías internas versionadas
!memory/audits/*.pdf
*.docx
*.xlsx
*.zip

# ─── Base de Datos ────────────────────────────────────────────────────────────
*.sql
*.sql.gz
*.sql.bz2
*.sqlite
*.sqlite3
*.db
CREATE_STAGING_DB.sql

# ─── Dependencias (no subir vendor de PHP/Node) ───────────────────────────────
git-deployer-app/vendor/
node_modules/

# ─── Archivos temporales / OS ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
wp-content/debug.log

# ─── Archivos de backup locales ───────────────────────────────────────────────
../configs/
*.bak
*.backup
*.orig

# Directorio de reportes generados (PDFs/HTML locales; no versionar)
reports/

# Progreso local cola Claude dispatch (no commitear)
memory/claude/dispatch-state.json

# Vault Obsidian / clones locales de referencia
.obsidian/
/vendor/

# Worktrees y artefactos locales de Claude Code
.claude/

# Agent Orchestrator (AO) - artefactos locales (opcional)
agent-orchestrator.yaml
agent-orchestrator.yml

# ─── Tooling local / vaults (no commitear) ────────────────────────────────────
.obsidian/

# Vendor local (repos clonados para referencia; se versionan solo si son submodules)
vendor/agentcraft/
vendor/graphify/

# Scripts con credenciales — NUNCA commitear
audit_content.php
cleanup_content.php
*.staging.php
