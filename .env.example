# ── Google Gemini ─────────────────────────────────────────────────────────────
# Bake-time key injected by Vite into the browser bundle.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── GoDaddy Reseller API ──────────────────────────────────────────────────────
# Credentials from the GoDaddy Developer Portal:
#   https://developer.godaddy.com  →  API Keys  →  Create New API Key
#
# Two separate environments are supported.  Store both so you can switch
# between them with the GODADDY_API_ENV variable (never commit real values).
#
# ── OTE (test / sandbox) ─────────────────────────────────────────────────────
GODADDY_OTE_API_KEY=your_ote_api_key_here
GODADDY_OTE_API_SECRET=your_ote_api_secret_here

# ── Production ────────────────────────────────────────────────────────────────
GODADDY_PROD_API_KEY=your_production_api_key_here
GODADDY_PROD_API_SECRET=your_production_api_secret_here

# ── Active environment selector ───────────────────────────────────────────────
# Set to OTE while developing/testing. Switch to PRODUCTION for live operations.
GODADDY_API_ENV=OTE
