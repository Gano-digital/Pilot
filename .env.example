# ── Google Gemini ─────────────────────────────────────────────────────────────
# Bake-time key injected by Vite into the browser bundle.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── GoDaddy Reseller API ──────────────────────────────────────────────────────
# Credentials from the GoDaddy Developer Portal:
#   https://developer.godaddy.com  →  API Keys  →  Create New API Key
#
# The portal displays a single combined key in the format  KEY_SECRET.
# Split it at the underscore:
#   GODADDY_API_KEY    ← the segment BEFORE the underscore
#   GODADDY_API_SECRET ← the segment AFTER  the underscore
#
# Leave GODADDY_API_ENV=OTE while developing/testing.
# Change to PRODUCTION only when you have live (non-OTE) credentials.
GODADDY_API_KEY=your_godaddy_api_key_here
GODADDY_API_SECRET=your_godaddy_api_secret_here
GODADDY_API_ENV=OTE
