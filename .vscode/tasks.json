{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Gano: validar cola Claude dispatch",
      "type": "shell",
      "command": "python",
      "args": ["scripts/validate_claude_dispatch.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Gano: Claude dispatch — siguiente tarea (next)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/claude_dispatch.py", "next"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Gano: Claude dispatch — listar",
      "type": "shell",
      "command": "python",
      "args": ["scripts/claude_dispatch.py", "list"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "Gano: Claude dispatch — mostrar tarea",
      "type": "shell",
      "command": "python",
      "args": ["scripts/claude_dispatch.py", "show", "${input:dispatchTaskId}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Gano: Claude dispatch — marcar completa",
      "type": "shell",
      "command": "python",
      "args": ["scripts/claude_dispatch.py", "complete", "${input:dispatchTaskId}"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Gano: validar cola Copilot (agent-queue)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/validate_agent_queue.py"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": false
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "dispatchTaskId",
      "type": "promptString",
      "description": "ID de tarea dispatch (ej. cd-repo-002)"
    }
  ]
}
